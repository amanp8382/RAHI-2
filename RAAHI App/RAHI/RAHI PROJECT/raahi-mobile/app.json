{
  "expo": {
    "name": "RAAHI",
    "slug": "raahi-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#f7f1eb"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "android": {
      "package": "com.raahi.mobile",
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION"
      ]
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow RAAHI to access your profile photo."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow RAAHI to access your live location for safety scoring."
        }
      ]
    ],
    "extra": {
      "apiBaseUrl": "http://10.0.2.2:5000/api"
    }
  }
}
